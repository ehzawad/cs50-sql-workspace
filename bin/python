#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TOOL="$ROOT/.venv-cs50/bin/python"

if [[ ! -x "$TOOL" ]]; then
    echo "Local Python environment not found at $TOOL" >&2
    echo "Run ./bin/bootstrap-workspace from $ROOT to rebuild the local course environment." >&2
    exit 1
fi

exec "$TOOL" "$@"
