#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONTAINER_NAME="cs50-sql-mysql"
MYSQL_IMAGE="${CS50_SQL_MYSQL_IMAGE:-mysql:8}"
MYSQL_ROOT_PASSWORD="${CS50_SQL_MYSQL_ROOT_PASSWORD:-crimson}"
DATA_DIR="$ROOT/data/mysql"

if ! command -v docker >/dev/null 2>&1; then
    echo "docker is required for the local MySQL setup." >&2
    exit 1
fi

mkdir -p "$DATA_DIR"

wait_for_mysql() {
    # Use a real authenticated query, not just `mysqladmin ping`, so the wait
    # loop fails loudly when the configured password does not match the
    # already-initialized data directory (i.e. password drift across
    # CS50_SQL_MYSQL_ROOT_PASSWORD changes).
    local pinged=false
    for _ in $(seq 1 60); do
        if docker exec "$CONTAINER_NAME" mysqladmin ping -uroot -p"$MYSQL_ROOT_PASSWORD" --silent >/dev/null 2>&1; then
            pinged=true
            if docker exec "$CONTAINER_NAME" mysql -uroot -p"$MYSQL_ROOT_PASSWORD" -e 'SELECT 1;' >/dev/null 2>&1; then
                return 0
            fi
        fi
        sleep 1
    done
    if "$pinged"; then
        echo "MySQL is responding but rejected the configured root password." >&2
        echo "If the data directory at $DATA_DIR was initialized under a different CS50_SQL_MYSQL_ROOT_PASSWORD," >&2
        echo "either export that same value or remove the directory and the '$CONTAINER_NAME' container, then retry." >&2
    else
        echo "MySQL container did not become ready in time." >&2
    fi
    return 1
}

if docker ps --format '{{.Names}}' | grep -Fxq "$CONTAINER_NAME"; then
    # Already running; still wait for the server to answer in case it is mid-startup.
    wait_for_mysql
    exit $?
fi

if docker ps -a --format '{{.Names}}' | grep -Fxq "$CONTAINER_NAME"; then
    docker start "$CONTAINER_NAME" >/dev/null
    wait_for_mysql
    exit $?
fi

docker run \
    --name "$CONTAINER_NAME" \
    -e MYSQL_ROOT_PASSWORD="$MYSQL_ROOT_PASSWORD" \
    -v "$DATA_DIR:/var/lib/mysql" \
    -v "$ROOT:/workspace" \
    -d \
    "$MYSQL_IMAGE" >/dev/null

wait_for_mysql
