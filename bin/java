#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
JAVA="$ROOT/vendor/jdk/bin/java"

if [[ ! -x "$JAVA" ]]; then
    echo "Local JDK not found at $JAVA" >&2
    echo "Run ./bin/bootstrap-workspace from $ROOT to download the ignored toolchain assets." >&2
    exit 1
fi

exec "$JAVA" "$@"
