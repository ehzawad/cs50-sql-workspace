#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OS_NAME="$(uname -s)"
ARCH_NAME="$(uname -m)"

case "$OS_NAME" in
    Linux) JDK_OS="linux" ;;
    Darwin) JDK_OS="mac" ;;
    *)
        echo "Unsupported operating system: $OS_NAME" >&2
        exit 1
        ;;
esac

case "$ARCH_NAME" in
    x86_64|amd64) JDK_ARCH="x64" ;;
    arm64|aarch64) JDK_ARCH="aarch64" ;;
    *)
        echo "Unsupported architecture: $ARCH_NAME" >&2
        exit 1
        ;;
esac

case "${OS_NAME}-${JDK_ARCH}" in
    Linux-x64)     SQLITE_TOOLS_DEFAULT="https://www.sqlite.org/2026/sqlite-tools-linux-x64-3530000.zip" ;;
    Linux-aarch64) SQLITE_TOOLS_DEFAULT="" ;;  # no prebuilt linux-arm64 tools zip from sqlite.org; rely on system sqlite3
    *)             SQLITE_TOOLS_DEFAULT="" ;;
esac
SQLITE_TOOLS_URL="${CS50_SQL_SQLITE_TOOLS_URL:-$SQLITE_TOOLS_DEFAULT}"
JDK_URL="${CS50_SQL_JDK_URL:-https://api.adoptium.net/v3/binary/latest/21/ga/${JDK_OS}/${JDK_ARCH}/jdk/hotspot/normal/eclipse}"

fetch_url() {
    local url="$1"
    local out="$2"
    if command -v wget >/dev/null 2>&1; then
        wget -O "$out" "$url"
    elif command -v curl >/dev/null 2>&1; then
        curl -L --fail --output "$out" "$url"
    else
        echo "Neither wget nor curl is available for downloading $url" >&2
        exit 1
    fi
}

fetch_if_missing_or_empty() {
    local url="$1"
    local out="$2"
    if [[ -s "$out" ]]; then
        return 0
    fi
    fetch_url "$url" "$out"
}

fetch_zip() {
    local url="$1"
    local out="$2"
    if [[ -f "$out" ]] && unzip -tq "$out" >/dev/null 2>&1; then
        return 0
    fi
    fetch_url "$url" "$out"
    unzip -tq "$out" >/dev/null
}

fetch_tgz() {
    local url="$1"
    local out="$2"
    if [[ -f "$out" ]] && tar -tzf "$out" >/dev/null 2>&1; then
        return 0
    fi
    fetch_url "$url" "$out"
    tar -tzf "$out" >/dev/null
}

# Locate a non-wrapper sqlite3 on PATH. The repo's bin/ may be on PATH; the
# wrapper in $ROOT/bin/sqlite3 would satisfy `command -v sqlite3` but defeats
# the point of asking "does the system have sqlite3".
#
# Normalize each PATH entry to an absolute path before comparing so that
# relative entries like `bin`, `./bin`, or `../cs50-sql-workspace/bin` do not
# slip past the self-check.
system_sqlite3_path() {
    local self="$ROOT/bin/sqlite3"
    local IFS=':'
    local dir abs_dir candidate
    for dir in $PATH; do
        [[ -z "$dir" ]] && continue
        abs_dir="$(cd "$dir" 2>/dev/null && pwd -P)" || continue
        candidate="$abs_dir/sqlite3"
        if [[ -x "$candidate" && "$candidate" != "$self" ]]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

download_sqlite_tools() {
    if [[ "$OS_NAME" == "Darwin" ]]; then
        if system_sqlite3_path >/dev/null; then
            echo "Using system sqlite3 on macOS."
            return 0
        fi
        echo "sqlite3 was not found on macOS. Install it with Homebrew: brew install sqlite" >&2
        exit 1
    fi

    if [[ -z "$SQLITE_TOOLS_URL" ]]; then
        if system_sqlite3_path >/dev/null; then
            echo "No prebuilt sqlite-tools archive is configured for ${OS_NAME}-${ARCH_NAME}; using system sqlite3."
            return 0
        fi
        echo "No prebuilt sqlite-tools archive is configured for ${OS_NAME}-${ARCH_NAME}, and no system sqlite3 was found." >&2
        echo "Install sqlite3 through your package manager, or set CS50_SQL_SQLITE_TOOLS_URL to a matching archive." >&2
        exit 1
    fi

    mkdir -p "$ROOT/downloads" "$ROOT/vendor/sqlite-tools"
    local zip="$ROOT/downloads/sqlite-tools-linux-x64-3530000.zip"
    fetch_zip "$SQLITE_TOOLS_URL" "$zip"
    unzip -oq "$zip" -d "$ROOT/vendor/sqlite-tools.tmp"
    find "$ROOT/vendor/sqlite-tools.tmp" -maxdepth 2 -type f | while read -r f; do
        mv "$f" "$ROOT/vendor/sqlite-tools/"
    done
    rm -rf "$ROOT/vendor/sqlite-tools.tmp"
    chmod +x "$ROOT/vendor/sqlite-tools/"* || true
}

download_jdk() {
    mkdir -p "$ROOT/downloads" "$ROOT/vendor/jdk"
    local tarball="$ROOT/downloads/temurin-21-jdk-${JDK_OS}-${JDK_ARCH}.tar.gz"
    fetch_tgz "$JDK_URL" "$tarball"
    local extract_dir="$ROOT/vendor/jdk.extract"
    rm -rf "$extract_dir"
    mkdir -p "$extract_dir"
    tar -xzf "$tarball" -C "$extract_dir" --strip-components=1
    # Temurin tarballs differ by OS:
    #   Linux:  <root>/bin/java
    #   macOS:  <root>/Contents/Home/bin/java
    local java_dir
    if [[ -x "$extract_dir/bin/java" ]]; then
        java_dir="$extract_dir"
    elif [[ -x "$extract_dir/Contents/Home/bin/java" ]]; then
        java_dir="$extract_dir/Contents/Home"
    else
        echo "Could not locate bin/java inside extracted JDK at $extract_dir" >&2
        exit 1
    fi
    rm -rf "$ROOT/vendor/jdk"
    mkdir -p "$ROOT/vendor/jdk"
    # Move the resolved Home directory contents into vendor/jdk so bin/java lives at vendor/jdk/bin/java on every OS.
    (cd "$java_dir" && tar -cf - .) | (cd "$ROOT/vendor/jdk" && tar -xf -)
    rm -rf "$extract_dir"
}

install_python_tools() {
    python3 -m venv "$ROOT/.venv-cs50"
    "$ROOT/.venv-cs50/bin/pip" install -U pip
    "$ROOT/.venv-cs50/bin/pip" install cs50 check50 submit50
    chmod +x "$ROOT/bin/"* || true
}

download_lecture_assets() {
    mkdir -p "$ROOT/downloads/lectures"
    for w in 0 1 2 3 4 5 6; do
        mkdir -p "$ROOT/docs/week${w}/raw" "$ROOT/cs50/week${w}"
        fetch_if_missing_or_empty "https://cs50.harvard.edu/sql/notes/${w}/" "$ROOT/docs/week${w}/raw/lecture${w}-notes.html"
        fetch_if_missing_or_empty "https://cdn.cs50.net/sql/2023/x/lectures/${w}/lang/en/lecture${w}.txt" "$ROOT/docs/week${w}/raw/lecture${w}-transcript.txt"
        fetch_if_missing_or_empty "https://cdn.cs50.net/sql/2023/x/lectures/${w}/lang/en/lecture${w}.srt" "$ROOT/docs/week${w}/raw/lecture${w}-subtitles.srt"
        fetch_zip "https://cdn.cs50.net/sql/2023/x/lectures/${w}/src${w}.zip" "$ROOT/downloads/lectures/src${w}.zip"
        unzip -nq "$ROOT/downloads/lectures/src${w}.zip" -d "$ROOT/cs50/week${w}"
    done
}

download_pset_assets() {
    mkdir -p "$ROOT/downloads/psets" "$ROOT/docs/psets/raw"

    while read -r rel; do
        [[ -z "$rel" ]] && continue
        fetch_zip "https://cdn.cs50.net/sql/2024/x/psets/${rel}" "$ROOT/downloads/psets/$(basename "$rel")"
    done <<'EOF'
0/cyberchase.zip
0/views.zip
0/normals.zip
0/players.zip
1/packages.zip
1/dese.zip
1/moneyball.zip
3/dont-panic.zip
3/meteorites.zip
4/census.zip
4/private.zip
4/bnb.zip
5/snap.zip
5/harvard.zip
6/deep.zip
6/dont-panic-python.zip
6/dont-panic-java.zip
EOF

    unzip -nq "$ROOT/downloads/psets/cyberchase.zip" -d "$ROOT/cs50/pset0"
    unzip -nq "$ROOT/downloads/psets/views.zip" -d "$ROOT/cs50/pset0"
    unzip -nq "$ROOT/downloads/psets/normals.zip" -d "$ROOT/cs50/pset0"
    unzip -nq "$ROOT/downloads/psets/players.zip" -d "$ROOT/cs50/pset0"

    mkdir -p "$ROOT/cs50/pset1" "$ROOT/cs50/pset3" "$ROOT/cs50/pset4" "$ROOT/cs50/pset5" "$ROOT/cs50/pset6"
    unzip -nq "$ROOT/downloads/psets/packages.zip" -d "$ROOT/cs50/pset1"
    unzip -nq "$ROOT/downloads/psets/dese.zip" -d "$ROOT/cs50/pset1"
    unzip -nq "$ROOT/downloads/psets/moneyball.zip" -d "$ROOT/cs50/pset1"
    unzip -nq "$ROOT/downloads/psets/dont-panic.zip" -d "$ROOT/cs50/pset3"
    unzip -nq "$ROOT/downloads/psets/meteorites.zip" -d "$ROOT/cs50/pset3"
    unzip -nq "$ROOT/downloads/psets/census.zip" -d "$ROOT/cs50/pset4"
    unzip -nq "$ROOT/downloads/psets/private.zip" -d "$ROOT/cs50/pset4"
    unzip -nq "$ROOT/downloads/psets/bnb.zip" -d "$ROOT/cs50/pset4"
    unzip -nq "$ROOT/downloads/psets/snap.zip" -d "$ROOT/cs50/pset5"
    unzip -nq "$ROOT/downloads/psets/harvard.zip" -d "$ROOT/cs50/pset5"
    unzip -nq "$ROOT/downloads/psets/deep.zip" -d "$ROOT/cs50/pset6"
    unzip -nq "$ROOT/downloads/psets/dont-panic-python.zip" -d "$ROOT/cs50/pset6"
    unzip -nq "$ROOT/downloads/psets/dont-panic-java.zip" -d "$ROOT/cs50/pset6"

    # PSet 2 is design-from-scratch, so bootstrap only guarantees blank schema scaffolds.
    for p in atl connect donuts; do
        mkdir -p "$ROOT/cs50/pset2/$p"
        [[ -f "$ROOT/cs50/pset2/$p/schema.sql" ]] || : > "$ROOT/cs50/pset2/$p/schema.sql"
    done

    mkdir -p "$ROOT/cs50/pset6/sentimental-connect"
    [[ -f "$ROOT/cs50/pset6/sentimental-connect/schema.sql" ]] || : > "$ROOT/cs50/pset6/sentimental-connect/schema.sql"

    mkdir -p "$ROOT/cs50/pset6/dont-panic"
    ln -sfn harvard "$ROOT/cs50/pset5/your.harvard"
    ln -sfn ../dont-panic-python "$ROOT/cs50/pset6/dont-panic/python"
    ln -sfn ../dont-panic-java "$ROOT/cs50/pset6/dont-panic/java"
}

download_pset_pages() {
    mkdir -p "$ROOT/docs/psets/raw"
    while read -r url; do
        [[ -z "$url" ]] && continue
        local_name="$(echo "$url" | sed 's#https://cs50.harvard.edu/sql/psets/##; s#/$##; s#/#-#g')"
        fetch_if_missing_or_empty "$url" "$ROOT/docs/psets/raw/${local_name}.html"
    done <<'EOF'
https://cs50.harvard.edu/sql/psets/0/cyberchase/
https://cs50.harvard.edu/sql/psets/0/views/
https://cs50.harvard.edu/sql/psets/0/normals/
https://cs50.harvard.edu/sql/psets/0/players/
https://cs50.harvard.edu/sql/psets/1/packages/
https://cs50.harvard.edu/sql/psets/1/dese/
https://cs50.harvard.edu/sql/psets/1/moneyball/
https://cs50.harvard.edu/sql/psets/2/atl/
https://cs50.harvard.edu/sql/psets/2/connect/
https://cs50.harvard.edu/sql/psets/2/donuts/
https://cs50.harvard.edu/sql/psets/3/dont-panic/
https://cs50.harvard.edu/sql/psets/3/meteorites/
https://cs50.harvard.edu/sql/psets/4/census/
https://cs50.harvard.edu/sql/psets/4/private/
https://cs50.harvard.edu/sql/psets/4/bnb/
https://cs50.harvard.edu/sql/psets/5/snap/
https://cs50.harvard.edu/sql/psets/5/your.harvard/
https://cs50.harvard.edu/sql/psets/6/connect/
https://cs50.harvard.edu/sql/psets/6/deep/
https://cs50.harvard.edu/sql/psets/6/dont-panic/python/
https://cs50.harvard.edu/sql/psets/6/dont-panic/java/
EOF
}

download_sqlite_tools
download_jdk
install_python_tools
download_lecture_assets
download_pset_assets
download_pset_pages

echo "Workspace bootstrap complete."
